{
  "name": "@repo/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema/index.ts",
    "./types": "./src/types/index.ts",
    "./validation": "./src/validation/index.ts",
    "./calculations": "./src/calculations/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "argon2": "^0.41.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
