# =============================================================================
# Environment Configuration - Immo Manager
# =============================================================================
# Copy this file to .env and fill in the values.
# cp .env.example .env

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/immo_manager

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# NEXT.JS
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# WEBSOCKET
# =============================================================================
WS_PORT=3002
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# =============================================================================
# AUTHENTICATION / JWT
# =============================================================================
# Secrets for JWT signing (min 32 characters each). Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-base64-48

# Email auto-promoted to admin role on registration
ADMIN_EMAIL=admin@example.com

# =============================================================================
# SMTP / E-MAIL (Nodemailer)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com

# =============================================================================
# ENCRYPTION
# =============================================================================
EMAIL_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=change-me
VAPID_PRIVATE_KEY=change-me
VAPID_SUBJECT=mailto:admin@immo-manager.local
NEXT_PUBLIC_VAPID_PUBLIC_KEY=change-me-same-as-VAPID_PUBLIC_KEY

# =============================================================================
# AI / GEMINI
# =============================================================================
# API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Maximum AI generations per user per day (default: 50)
AI_DAILY_LIMIT_PER_USER=50
