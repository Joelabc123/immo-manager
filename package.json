{
  "name": "immo-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @repo/nextjs dev",
    "build": "pnpm --filter @repo/nextjs build",
    "start": "pnpm --filter @repo/nextjs start",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @repo/shared db:generate",
    "db:push": "pnpm --filter @repo/shared db:push",
    "db:migrate": "pnpm --filter @repo/shared db:migrate",
    "db:studio": "pnpm --filter @repo/shared db:studio"
  },
  "devDependencies": {
    "eslint": "^9",
    "prettier": "^3.8.1",
    "typescript": "^5"
  }
}
